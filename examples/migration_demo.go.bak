package migrationdemo

import (
	"fmt"
	"log"
	"time"

	"tesselbox/pkg/entities"
)

func RunMigrationDemo() {
	fmt.Println("=== TesselBox Migration Demo ===")

	// Initialize migration system
	entities.InitializeMigration()
	mm := entities.GetGlobalMigrationManager()

	fmt.Printf("Initial migration step: %d\n", mm.GetMigrationStep())

	// Demo migration phases
	fmt.Println("\n--- Testing Migration Phases ---")

	// Phase 0: Old system only
	fmt.Println("Phase 0: Old system only")
	mm.SetMigrationStep(0)
	testSystemUsage(mm, "blocks")
	testSystemUsage(mm, "items")
	testSystemUsage(mm, "organisms")
	printMigrationProgress(mm)

	// Phase 1: Hybrid - blocks only
	fmt.Println("\nPhase 1: Hybrid - blocks migrated")
	mm.SetMigrationStep(1)
	testSystemUsage(mm, "blocks")
	testSystemUsage(mm, "items")
	testSystemUsage(mm, "organisms")
	printMigrationProgress(mm)

	// Phase 2: Hybrid - blocks and items
	fmt.Println("\nPhase 2: Hybrid - blocks and items migrated")
	mm.SetMigrationStep(2)
	testSystemUsage(mm, "blocks")
	testSystemUsage(mm, "items")
	testSystemUsage(mm, "organisms")
	printMigrationProgress(mm)

	// Phase 3: Hybrid - all systems
	fmt.Println("\nPhase 3: Hybrid - all systems migrated")
	mm.SetMigrationStep(3)
	testSystemUsage(mm, "blocks")
	testSystemUsage(mm, "items")
	testSystemUsage(mm, "organisms")
	printMigrationProgress(mm)

	// Phase 4: New system primary
	fmt.Println("\nPhase 4: New system primary")
	mm.SetMigrationStep(4)
	testSystemUsage(mm, "blocks")
	testSystemUsage(mm, "items")
	testSystemUsage(mm, "organisms")
	printMigrationProgress(mm)

	// Phase 5: New system only
	fmt.Println("\nPhase 5: New system only")
	mm.SetMigrationStep(5)
	testSystemUsage(mm, "blocks")
	testSystemUsage(mm, "items")
	testSystemUsage(mm, "organisms")
	printMigrationProgress(mm)

	// Test entity creation during migration
	fmt.Println("\n--- Testing Entity Creation During Migration ---")
	testEntityCreation(mm)

	// Test event system
	fmt.Println("\n--- Testing Event System ---")
	testEventSystem(mm)

	// Test performance
	fmt.Println("\n--- Testing Performance ---")
	testPerformance(mm)

	// Final statistics
	fmt.Println("\n--- Final Migration Statistics ---")
	finalStats := mm.GetMigrationProgress()
	fmt.Printf("Final migration ratio: %.2f%%\n", finalStats["migration_ratio"].(float64)*100)
	fmt.Printf("Total old system usage: %d\n", finalStats["total_old_usage"])
	fmt.Printf("Total new system usage: %d\n", finalStats["total_new_usage"])

	// Shutdown
	fmt.Println("\n--- Shutting Down ---")
	if err := mm.Shutdown(); err != nil {
		log.Printf("Error during shutdown: %v", err)
	}

	fmt.Println("=== Migration Demo Complete ===")
}

func testSystemUsage(mm *entities.MigrationManager, system string) {
	// Test if new system should be used
	shouldUse := mm.ShouldUseNewSystem(system)
	fmt.Printf("  %s: Should use new system? %v\n", system, shouldUse)

	// Simulate usage
	if shouldUse {
		mm.RecordNewSystemUsage(system)
	} else {
		mm.RecordOldSystemUsage(system)
	}
}

func printMigrationProgress(mm *entities.MigrationManager) {
	progress := mm.GetMigrationProgress()
	fmt.Printf("  Migration ratio: %.2f%%\n", progress["migration_ratio"].(float64)*100)
	fmt.Printf("  Old usage: %d, New usage: %d\n",
		progress["total_old_usage"], progress["total_new_usage"])
}

func testEntityCreation(mm *entities.MigrationManager) {
	// Test creating entities at different migration steps
	testSteps := []int{0, 2, 4, 5}

	for _, step := range testSteps {
		fmt.Printf("Testing entity creation at step %d:\n", step)
		mm.SetMigrationStep(step)

		// Try to create different entity types
		err1 := entities.CreateEntityUsingNewSystem("blocks", "stone", 10, 20, 30, 1, "player1")
		err2 := entities.CreateEntityUsingNewSystem("items", "sword", 0, 0, 0, 1, "player1")
		err3 := entities.CreateEntityUsingNewSystem("organisms", "tree", 50, 60, 70, 1, "player1")

		fmt.Printf("  Block creation: %v\n", err1 == nil)
		fmt.Printf("  Item creation: %v\n", err2 == nil)
		fmt.Printf("  Organism creation: %v\n", err3 == nil)
	}

	// Reset to full migration
	mm.SetMigrationStep(5)
}

func testEventSystem(mm *entities.MigrationManager) {
	bridge := mm.GetBridge()
	world := bridge.GetWorld()
	eventBus := world.GetEventBus()

	// Subscribe to events
	eventReceived := false
	eventBus.Subscribe(entities.EventEntityAdded, func(event entities.Event) {
		eventReceived = true
		fmt.Printf("  Received event: %s\n", event.Type)
	})

	// Create an entity to trigger event
	err := bridge.CreateBlock("test_block", 100, 200, 300)
	if err != nil {
		fmt.Printf("  Error creating test block: %v\n", err)
		return
	}

	// Wait for event processing
	time.Sleep(100 * time.Millisecond)

	if eventReceived {
		fmt.Printf("  Event system working correctly\n")
	} else {
		fmt.Printf("  Event system not working\n")
	}
}

func testPerformance(mm *entities.MigrationManager) {
	bridge := mm.GetBridge()
	world := bridge.GetWorld()

	// Test entity creation performance
	start := time.Now()
	entityCount := 100

	for i := 0; i < entityCount; i++ {
		world.CreateBlock(fmt.Sprintf("block_%d", i), float64(i), 0, 0)
	}

	creationTime := time.Since(start)
	fmt.Printf("  Created %d entities in %v (%.2f entities/sec)\n",
		entityCount, creationTime, float64(entityCount)/creationTime.Seconds())

	// Test update performance
	start = time.Now()
	for i := 0; i < 60; i++ { // 1 second of updates at 60 FPS
		world.Update(1.0 / 60.0)
	}
	updateTime := time.Since(start)
	fmt.Printf("  Updated %d entities for 1 second in %v\n", entityCount, updateTime)

	// Test query performance
	start = time.Now()
	for i := 0; i < 100; i++ {
		world.GetEntitiesByType("block")
	}
	queryTime := time.Since(start)
	fmt.Printf("  Queried entities 100 times in %v (%.2f queries/sec)\n",
		queryTime, 100.0/queryTime.Seconds())
}
